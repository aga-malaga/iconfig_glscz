{
  "manifest_version": 3,
  "name": "GLS CZ - integracja z Apilo",
  "version": "1.8",
  "description": "Rozszerzenie łączące Apilo z GLS CZ by iConfig.pl",
  "permissions": [
    "storage",
    "alarms", "downloads"
  ],
  "host_permissions": [
    "http://localhost:8080/*"
  ],
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "js": [
        "contentScript.js"
      ],
      "matches": [
        "https://*.apilo.com/*", "https://*.apilo.dev/*"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "action": {
    "default_title": "Ustawienia GLS CZ",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  }
}
